{
  "name": "code-explainer",
  "displayName": "Code Explainer",
  "description": "Explain highlighted code using AI",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:code-explainer.explainCode"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "code-explainer.explainCode",
        "title": "Code Explainer: Explain Code"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.99.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
